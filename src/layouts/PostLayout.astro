---
import BaseLayout from './BaseLayout.astro';

interface HeadingLike {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  lang?: 'en';
  canonicalUrl: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags: string[];
  readingTime: number;
  backHref: string;
  backLabel: string;
  headings?: HeadingLike[];
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  ogImage?: string;
}

const {
  title,
  description,
  lang = 'en',
  canonicalUrl,
  publishedAt,
  updatedAt,
  tags,
  readingTime,
  backHref,
  backLabel,
  headings = [],
  jsonLd,
  ogImage,
} = Astro.props;

const locale = 'en-US';
const formattedPublishedAt = new Intl.DateTimeFormat(locale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(publishedAt);

const showUpdated =
  updatedAt && updatedAt.getTime() !== publishedAt.getTime();

const formattedUpdatedAt = showUpdated
  ? new Intl.DateTimeFormat(locale, {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).format(updatedAt)
  : undefined;

const ui = {
  published: 'Published',
  updated: 'Updated',
  readingTime: 'min read',
  toc: 'On this page',
};

const tocHeadings = headings.filter((heading) => {
  return heading.depth >= 2 && heading.depth <= 3;
});
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
  ogImage={ogImage}
>
  <section class="post-page">
    <div class="container--wide post-page__inner">
      <article class="post-article">
        <a class="post-back" href={backHref}>{backLabel}</a>

        <header class="post-header">
          <div class="post-meta" aria-label="Post metadata">
            <span>{ui.published}: <time datetime={publishedAt.toISOString()}>{formattedPublishedAt}</time></span>
            {formattedUpdatedAt && (
              <span>{ui.updated}: <time datetime={updatedAt?.toISOString()}>{formattedUpdatedAt}</time></span>
            )}
            <span>{readingTime} {ui.readingTime}</span>
          </div>

          <h1>{title}</h1>
          <p class="post-lead">{description}</p>

          <div class="post-header__footer">
            {tags.length > 0 && (
              <div class="post-tags" aria-label="Post topics">
                {tags.map((tag) => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </header>

        <div class="post-layout">
          <div class="post-body">
            <slot />
          </div>

          {tocHeadings.length > 1 && (
            <aside class="post-toc" aria-label={ui.toc}>
              <div class="post-toc__card">
                <h2>{ui.toc}</h2>
                <nav>
                  <ul class="post-toc__list">
                    {tocHeadings.map((heading) => (
                      <li
                        class:list={[
                          'post-toc__item',
                          heading.depth === 3 && 'post-toc__item--nested',
                        ]}
                      >
                        <a href={`#${heading.slug}`}>{heading.text}</a>
                      </li>
                    ))}
                  </ul>
                </nav>
              </div>
            </aside>
          )}
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
.post-page__inner {
  width: min(100% - 2rem, var(--container-wide));
}

.post-article {
  max-width: 100%;
}

.post-back {
  display: inline-flex;
  margin-bottom: 1rem;
  color: var(--color-primary-dark);
  font-size: 0.92rem;
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 0.18em;
}

.post-header {
  margin-bottom: 1.25rem;
}

.post-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm) var(--space-lg);
  margin-bottom: var(--space-md);
  color: var(--color-text-muted);
  font-family: var(--font-mono);
  font-size: 0.8rem;
}

.post-header h1 {
  max-width: none;
  margin-bottom: 0.75rem;
  font-size: clamp(2.4rem, 5vw, 4rem);
  line-height: 1.08;
  letter-spacing: -0.02em;
}

.post-lead {
  max-width: 60ch;
  margin-bottom: 1rem;
  color: var(--color-text-secondary);
  line-height: 1.74;
}

.post-header__footer {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.post-tag {
  display: inline-flex;
  padding: 0.25rem 0.7rem;
  border: 1px solid var(--color-border);
  border-radius: 999px;
  background: var(--color-background-secondary);
  color: var(--color-text-secondary);
  font-size: 0.8rem;
  font-weight: 600;
}

.post-translation {
  color: var(--color-accent);
  font-size: 0.92rem;
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 0.18em;
}

.post-layout {
  display: grid;
  gap: 1.5rem;
}

.post-body {
  min-width: 0;
}

.post-body :global(*) {
  scroll-margin-top: 6.5rem;
}

.post-body :global(h2),
.post-body :global(h3),
.post-body :global(h4) {
  margin-top: var(--space-2xl);
  margin-bottom: var(--space-md);
}

.post-body :global(p),
.post-body :global(li) {
  color: var(--color-text-secondary);
  font-size: 1.02rem;
  line-height: 1.78;
}

.post-body :global(a) {
  color: var(--color-primary-dark);
  text-decoration: underline;
  text-decoration-thickness: 0.08em;
  text-underline-offset: 0.2em;
}

.post-body :global(strong) {
  color: var(--color-text-primary);
}

.post-body :global(blockquote) {
  margin: var(--space-xl) 0;
  padding: var(--space-md) var(--space-lg);
  border-left: 4px solid var(--color-primary);
  background: var(--color-background-secondary);
  color: var(--color-text-secondary);
}

.post-body :global(pre) {
  margin: var(--space-xl) 0;
  padding: var(--space-lg);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-md);
  overflow-x: auto;
}

.post-body :global(code) {
  font-family: var(--font-mono);
  font-size: 0.92em;
}

.post-body :global(:not(pre) > code) {
  padding: 0.12rem 0.35rem;
  border-radius: var(--radius-sm);
  background: var(--color-background-secondary);
}

.post-body :global(img) {
  margin: var(--space-xl) 0;
  border-radius: var(--radius-md);
}

.post-body :global(hr) {
  margin-block: var(--space-2xl);
}

.post-body :global(table) {
  width: 100%;
  margin: var(--space-xl) 0;
  border-collapse: collapse;
  font-size: 0.95rem;
}

.post-body :global(th),
.post-body :global(td) {
  padding: 0.75rem;
  border: 1px solid var(--color-border-subtle);
  text-align: left;
}

.post-toc {
  display: none;
}

.post-toc__card {
  padding: 1rem 1.1rem;
}

.post-toc__card h2 {
  font-size: 0.95rem;
  margin-bottom: var(--space-md);
}

.post-toc__list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  gap: var(--space-sm);
}

.post-toc__item a {
  color: var(--color-text-secondary);
  font-size: 0.9rem;
  line-height: 1.45;
}

.post-toc__item--nested {
  padding-left: var(--space-md);
}

@media (min-width: 1025px) {
  .post-layout {
    grid-template-columns: minmax(0, 1fr) 260px;
    align-items: start;
  }

  .post-toc {
    display: block;
    position: sticky;
    top: 6.5rem;
  }
}
</style>

<style>
.page-header {
  align-items: center;
}

.page-header__photo-wrap {
  display: flex;
  justify-content: flex-start;
}

.page-header__photo,
.page-header__photo-fallback {
  width: min(100%, 220px);
  aspect-ratio: 4 / 5;
  border-radius: 28px;
}

.page-header__photo {
  object-fit: cover;
  background: var(--color-surface-soft);
  box-shadow: var(--shadow-soft);
}

.page-header__photo-fallback {
  display: grid;
  place-items: center;
  border: 1px solid var(--color-border);
  background:
    radial-gradient(circle at top left, rgb(185 137 68 / 0.18), transparent 26%),
    linear-gradient(180deg, rgb(255 255 255 / 0.92), rgb(255 255 255 / 0.74));
  color: var(--color-primary);
  font-size: clamp(2.3rem, 6vw, 3.8rem);
  font-weight: 700;
  letter-spacing: -0.08em;
  box-shadow: var(--shadow-soft);
}

.page-header__name {
  max-width: none;
  margin-bottom: 0;
  font-size: clamp(2.4rem, 5vw, 4rem);
}

.page-header__text {
  display: grid;
  gap: 0.65rem;
}

.page-header__titles {
  margin: 0;
  color: var(--color-text-secondary);
  font-size: 1.05rem;
  line-height: 1.5;
}

.page-header__badges {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: 0.25rem;
}

.badge {
  display: inline-block;
  padding: 0.3rem 0.75rem;
  border-radius: 999px;
  background: var(--color-background-secondary);
  border: 1px solid var(--color-border);
  color: var(--color-text-secondary);
  font-size: 0.8rem;
  font-weight: 600;
}

.badge--accent {
  background: color-mix(in srgb, var(--color-primary) 10%, transparent);
  border-color: var(--color-primary-light);
  color: var(--color-primary-dark);
}

/* ── Prose sections ── */
.prose-section {
  gap: 1rem;
}

.prose-section:last-child {
  border-bottom: none;
}

.prose-section h2 {
  margin-bottom: 0;
  color: var(--color-text-primary);
}

.prose-section p,
.prose-section ul,
.prose-section ol {
  color: var(--color-text-secondary);
  font-size: 1rem;
  line-height: 1.75;
}

.prose-section a {
  color: var(--color-primary-dark);
  text-decoration: underline;
}

/* ── Timeline ── */
.timeline {
  display: grid;
  gap: 1rem;
}

.timeline__item {
  display: grid;
  grid-template-columns: 140px 1fr;
  gap: 1rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--color-border-subtle);
}

.timeline__item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.timeline__period {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-primary);
  padding-top: 0.15rem;
}

.timeline__role {
  display: block;
  font-size: 1rem;
  color: var(--color-text-primary);
  margin-bottom: 0.2rem;
}

.timeline__org {
  display: block;
  font-size: 0.9rem;
  color: var(--color-text-muted);
  margin-bottom: var(--space-sm);
}

.timeline__detail {
  margin: 0;
  line-height: 1.65;
}

/* ── Education ── */
.edu-list { display: grid; gap: var(--space-md); }

.edu-item {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  padding: var(--space-md) var(--space-lg);
  background: var(--color-background-secondary);
  border-radius: var(--radius-md);
  border-left: 3px solid var(--color-primary);
}

.edu-item__degree {
  font-weight: 600;
  color: var(--color-text-primary);
}

.edu-item__institution {
  font-size: 0.9rem;

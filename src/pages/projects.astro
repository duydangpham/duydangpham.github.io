---
import { projectCategories } from '../data/projects';
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Projects';
const description =
  'Selected consulting, training, and conference projects by Dr. Duy Dang-Pham across AI adoption, digital transformation, standards, and information security.';
const canonicalUrl = '/projects';

const totalProjects = projectCategories.reduce((count, category) => {
  return count + category.projects.length;
}, 0);
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  canonicalUrl={canonicalUrl}
>
  <div class="container projects-page">
    <header class="page-header">
      <h1>Projects</h1>
      <p class="lead">
        Selected consulting, training, and conference engagements spanning AI adoption,
        digital transformation, standards development, information security governance,
        and public-sector capability building.
      </p>
    </header>

    <section class="section-block projects-overview">
      <div>
        <p class="projects-overview__eyebrow">Portfolio overview</p>
        <p class="projects-overview__copy">
          {totalProjects} selected engagements organised into three practice lanes.
        </p>
      </div>

      <nav class="projects-overview__nav" aria-label="Jump to project category">
        {projectCategories.map((category) => (
          <a class="tag projects-overview__link" href={`#${category.slug}`}>
            {category.label}
          </a>
        ))}
      </nav>
    </section>

    {projectCategories.map((category) => (
      <section class="project-group section-block" id={category.slug}>
        <div class="project-group__header">
          <div>
            <p class="project-group__eyebrow">{category.label}</p>
            <h2 class="project-group__title">{category.label} projects</h2>
          </div>
          <p class="project-group__count">
            {category.projects.length} engagement{category.projects.length === 1 ? '' : 's'}
          </p>
        </div>

        <div class="projects-grid">
          {category.projects.map((project) => (
            <article class="project-card card" data-project-card>
              <div class="project-card__media">
                <img
                  class="project-card__image"
                  src={project.thumbnail}
                  alt={`Project thumbnail for ${project.title}`}
                  loading="lazy"
                />
              </div>

              <div class="project-card__body">
                <h3 class="project-card__title">{project.title}</h3>
                <p class="project-card__client">{project.client}</p>

                <details class="project-card__details">
                  <summary class="project-card__summary">
                    <span>Project description</span>
                    <span class="project-card__summary-icon" aria-hidden="true"></span>
                  </summary>

                  <div class="project-card__details-body">
                    <p class="project-card__description">{project.description}</p>

                    {project.legacyUrl && (
                      <p class="project-card__reference">
                        <a href={project.legacyUrl} target="_blank" rel="noopener noreferrer">
                          View legacy gallery
                        </a>
                      </p>
                    )}
                  </div>
                </details>
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
.projects-page {
  display: grid;
  gap: 1.1rem;
}

.projects-overview {
  display: grid;
  gap: 1rem;
  align-items: center;
}

.projects-overview__eyebrow,
.project-group__eyebrow {
  margin-bottom: 0.45rem;
  color: var(--color-text-muted);
  font-size: 0.74rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.projects-overview__copy,
.project-group__count {
  margin: 0;
  color: var(--color-text-secondary);
  font-size: var(--text-sm);
}

.projects-overview__nav {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.projects-overview__link {
  text-decoration: none;
}

.project-group__header {
  display: flex;
  flex-wrap: wrap;
  align-items: end;
  justify-content: space-between;
  gap: 0.85rem;
  margin-bottom: 0.35rem;
}

.project-group__title {
  margin-bottom: 0;
  font-size: clamp(1.45rem, 2vw, 1.8rem);
}

.projects-grid {
  display: grid;
  gap: 1rem;
}

.project-card {
  overflow: hidden;
  display: grid;
  gap: 0;
  padding: 0;
}

.project-card__media {
  position: relative;
  overflow: hidden;
  aspect-ratio: 1.22;
  background:
    radial-gradient(circle at top right, rgb(185 137 68 / 0.18), transparent 24%),
    linear-gradient(180deg, rgb(255 255 255 / 0.9), rgb(243 245 248 / 0.88));
}

.project-card__media a {
  display: block;
  height: 100%;
}

.project-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.project-card__body {
  display: grid;
  gap: 0.55rem;
  padding: 1rem 1rem 1.1rem;
}

.project-card__title {
  margin-bottom: 0;
  font-size: 1.08rem;
  line-height: 1.26;
}

.project-card__client {
  margin: 0;
  color: var(--color-text-secondary);
  font-size: var(--text-sm);
  line-height: 1.6;
}

.project-card__details {
  margin-top: 0.1rem;
  border-top: 1px solid var(--color-border-subtle);
  padding-top: 0.9rem;
}

.project-card__summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.8rem;
  color: var(--color-primary-dark);
  font-size: 0.92rem;
  font-weight: 700;
  cursor: pointer;
  list-style: none;
}

.project-card__summary::-webkit-details-marker {
  display: none;
}

.project-card__summary-icon {
  position: relative;
  width: 0.9rem;
  height: 0.9rem;
  flex-shrink: 0;
}

.project-card__summary-icon::before,
.project-card__summary-icon::after {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0.72rem;
  height: 1.5px;
  border-radius: 999px;
  background: currentColor;
  transform: translate(-50%, -50%);
  content: '';
}

.project-card__summary-icon::after {
  transform: translate(-50%, -50%) rotate(90deg);
  transition: transform 180ms ease;
}

.project-card__details[open] .project-card__summary-icon::after {
  transform: translate(-50%, -50%) rotate(0deg);
}

.project-card__details-body {
  display: grid;
  gap: 0.75rem;
  padding-top: 0.8rem;
}

.project-card__description,
.project-card__reference {
  margin: 0;
  color: var(--color-text-secondary);
  font-size: var(--text-sm);
  line-height: 1.65;
}

.project-card__reference a {
  color: var(--color-primary-dark);
  text-decoration: underline;
  text-decoration-thickness: 0.08em;
  text-underline-offset: 0.18em;
}

@media (min-width: 768px) {
  .projects-overview {
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
  }

  .projects-overview__nav {
    justify-content: end;
  }

  .projects-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (min-width: 1100px) {
  .projects-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}
</style>

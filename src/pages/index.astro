---
import { homeSchema } from '../data/schema-home';
import BaseLayout from '../layouts/BaseLayout.astro';
import { hasProfilePortrait, profilePortraitSrc } from '../utils/portrait';

const title = 'Home';
const description =
  'Associate Head of Department (Research & Innovation) at RMIT University Vietnam, Senior Lecturer in MIS, and Co-Founder of NetIQ';
const canonicalUrl = '/';
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  canonicalUrl={canonicalUrl}
  jsonLd={homeSchema}
>
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="hero__eyebrow">
          Associate Head of Department · RMIT University Vietnam · Co-Founder, NetIQ
        </p>
        <h1 class="hero__name">Dr. Duy Dang-Pham</h1>
        <p class="hero__tagline">
          In the age of AI, the most important thing to understand is still the humans.
          I use Organisational Network Analysis to map the invisible networks of
          influence, trust, and knowledge inside organisations — helping leaders act on
          what they find, and helping researchers push the field forward.
        </p>
        <div class="hero__actions">
          <a class="btn btn--primary" href="/netiq">Work with NetIQ</a>
          <a class="btn btn--secondary" href="/research">Explore my research</a>
          <a class="btn btn--netiq" href="/speaking">Invite me to speak</a>
        </div>
      </div>

      <div class="hero__photo-wrap">
        <div class="hero__photo-card">
          {hasProfilePortrait && profilePortraitSrc ? (
            <img
              class="hero__photo"
              src={profilePortraitSrc}
              alt="Portrait of Dr. Duy Dang-Pham"
              width="420"
              height="520"
              loading="eager"
            />
          ) : (
            <div class="hero__photo-fallback" aria-hidden="true">DD</div>
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="metrics" aria-label="Key facts">
    <div class="container metrics__grid">
      <article class="metric-card">
        <span class="metric-card__value">70+</span>
        <span class="metric-card__label">Peer-reviewed publications</span>
      </article>
      <article class="metric-card">
        <span class="metric-card__value">15+</span>
        <span class="metric-card__label">Years in MIS field</span>
      </article>
      <article class="metric-card">
        <span class="metric-card__value">2024</span>
        <span class="metric-card__label">Fulbright Scholar-in-Residence</span>
      </article>
      <article class="metric-card">
        <span class="metric-card__value">11</span>
        <span class="metric-card__label">PhD candidates supervised</span>
      </article>
    </div>
  </section>

  <section class="section research-areas">
    <div class="container">
      <div class="section__header">
        <p class="section__eyebrow">Research</p>
        <h2 class="section__title">
          Research <span class="type-accent">focus</span>
        </h2>
        <p class="section__lead">
          My research maps what org charts cannot: the invisible networks of trust,
          influence, and knowledge that determine whether AI is adopted,
          transformation takes hold, and security cultures stick. Every finding is
          built to be used — not just published.
        </p>
      </div>

      <div class="cards">
        <article class="card card--ona">
          <div class="card__icon" aria-hidden="true">⬡</div>
          <h3 class="card__title">Organisational Network Analysis</h3>
          <p class="card__body">
            Using multiplex network methods — Work Advice, AI Support, Trust,
            Information, and Collaboration ties — to reveal the invisible architecture
            of how organisations actually function.
          </p>
          <a class="card__link" href="/concepts/organizational-network-analysis">
            Learn about ONA
          </a>
        </article>

        <article class="card card--ai">
          <div class="card__icon" aria-hidden="true">◈</div>
          <h3 class="card__title">AI Champion Programs</h3>
          <p class="card__body">
            Identifying Oracle, Broker, and Silo-Buster archetypes within organisations
            using betweenness centrality and community-detection algorithms to drive
            grass-roots AI adoption.
          </p>
          <a class="card__link" href="/concepts/ai-champions">
            Learn about AI Champions
          </a>
        </article>

        <article class="card card--sec">
          <div class="card__icon" aria-hidden="true">◉</div>
          <h3 class="card__title">Information Security Governance</h3>
          <p class="card__body">
            Examining how individuals, teams, and organisations protect digital assets —
            from end-user security behaviour to enterprise-level governance frameworks
            in Vietnamese and ASEAN contexts.
          </p>
          <a class="card__link" href="/research">Explore research</a>
        </article>

        <article class="card card--dt">
          <div class="card__icon" aria-hidden="true">◲</div>
          <h3 class="card__title">Digital Transformation</h3>
          <p class="card__body">
            Studying how organisations navigate large-scale technology change — change
            management, knowledge transfer, technology acceptance, and the social
            dynamics underpinning successful transformation.
          </p>
          <a class="card__link" href="/research">Explore research</a>
        </article>
      </div>

      <div class="section__footer">
        <a class="btn btn--outline" href="/publications">View all publications</a>
      </div>
    </div>
  </section>

  <section class="section netiq-spotlight">
    <div class="container">
      <div class="netiq-spotlight__panel">
        <div class="netiq-spotlight__text">
          <p class="section__eyebrow section__eyebrow--light">Consulting & Training</p>
          <h2 class="netiq-spotlight__title">
            NetIQ <span class="type-accent type-accent--light">spotlight</span>
          </h2>
          <p class="netiq-spotlight__body">
            Most AI transformation programmes are built on the org chart. But the org
            chart doesn't show who actually shapes opinion, moves knowledge, or carries
            informal influence. NetIQ does. As Vietnam's specialist in Organisational
            Network Analysis and AI strategy, we give leadership teams the data-driven
            maps they need to make transformation work — not just on paper.
          </p>

          <ul class="netiq-spotlight__services" aria-label="NetIQ service areas">
            <li>ONA Consulting &amp; Diagnostics</li>
            <li>AI Strategy Training for Executives</li>
            <li>AI Champion Program Design</li>
            <li>Research &amp; Advisory Services</li>
          </ul>

          <div class="netiq-spotlight__actions">
            <a class="btn btn--light" href="/netiq">Learn about NetIQ</a>
            <a class="btn btn--ghost" href="/contact">Contact</a>
          </div>
        </div>

        <div class="netiq-spotlight__visual" aria-hidden="true">
          <svg viewBox="0 0 260 260" fill="none" xmlns="http://www.w3.org/2000/svg" class="network-svg">
            <circle cx="130" cy="130" r="24" fill="#FFFFFF" opacity="0.96" />
            <circle cx="64" cy="72" r="15" fill="#F4C166" opacity="0.92" />
            <circle cx="198" cy="72" r="15" fill="#F4C166" opacity="0.92" />
            <circle cx="58" cy="194" r="13" fill="#FFFFFF" opacity="0.68" />
            <circle cx="202" cy="194" r="13" fill="#FFFFFF" opacity="0.68" />
            <circle cx="130" cy="34" r="11" fill="#FFFFFF" opacity="0.54" />
            <circle cx="34" cy="130" r="10" fill="#F4C166" opacity="0.6" />
            <circle cx="226" cy="130" r="10" fill="#F4C166" opacity="0.6" />
            <circle cx="130" cy="226" r="11" fill="#FFFFFF" opacity="0.54" />
            <line x1="130" y1="130" x2="64" y2="72" stroke="#FFFFFF" stroke-width="1.6" opacity="0.32" />
            <line x1="130" y1="130" x2="198" y2="72" stroke="#FFFFFF" stroke-width="1.6" opacity="0.32" />
            <line x1="130" y1="130" x2="58" y2="194" stroke="#FFFFFF" stroke-width="1.3" opacity="0.28" />
            <line x1="130" y1="130" x2="202" y2="194" stroke="#FFFFFF" stroke-width="1.3" opacity="0.28" />
            <line x1="130" y1="130" x2="130" y2="34" stroke="#F4C166" stroke-width="1.2" opacity="0.4" />
            <line x1="130" y1="130" x2="34" y2="130" stroke="#F4C166" stroke-width="1.2" opacity="0.4" />
            <line x1="130" y1="130" x2="226" y2="130" stroke="#F4C166" stroke-width="1.2" opacity="0.4" />
            <line x1="130" y1="130" x2="130" y2="226" stroke="#F4C166" stroke-width="1.2" opacity="0.4" />
          </svg>
        </div>
      </div>
    </div>
  </section>

  <section class="section recent">
    <div class="container">
      <div class="section__header">
        <p class="section__eyebrow">Selected milestones</p>
        <h2 class="section__title">
          Recent <span class="type-accent">highlights</span>
        </h2>
      </div>

      <div class="highlights">
        <article class="highlight">
          <span class="highlight__date">2025</span>
          <p class="highlight__text">
            Appointed <strong>Associate Head of Department (Research &amp; Innovation)</strong>
            at RMIT University Vietnam, leading research strategy and innovation across
            the School of Business &amp; Management.
          </p>
        </article>

        <article class="highlight">
          <span class="highlight__date">2024</span>
          <p class="highlight__text">
            Served as <strong>Fulbright Scholar-in-Residence</strong> at Gonzaga
            University, Spokane, USA — delivering lectures on AI strategy and ONA to
            American students and faculty.
          </p>
        </article>

        <article class="highlight">
          <span class="highlight__date">2024</span>
          <p class="highlight__text">
            VAIS hosted the <strong>Pacific Asia Conference on Information Systems (PACIS 2024)</strong>
            in Ho Chi Minh City — the largest IS research and industry conference in
            the Asia-Pacific.
          </p>
        </article>

        <article class="highlight">
          <span class="highlight__date">2023</span>
          <p class="highlight__text">
            Co-authored research on <strong>AI champion identification using ONA</strong>,
            introducing Oracle, Broker, and Silo-Buster archetypes that guide enterprise
            AI adoption programmes.
          </p>
        </article>
      </div>

      <div class="section__footer">
        <a class="btn btn--outline" href="/insights/">Read Insights</a>
        <a class="btn btn--secondary" href="/speaking">Speaking engagements</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.hero {
  padding-block: 0.75rem var(--space-lg);
}

.hero__inner {
  position: relative;
  overflow: hidden;
  display: grid;
  gap: var(--space-2xl);
  align-items: center;
  padding: clamp(1.6rem, 4vw, 3.1rem);
  border: 1px solid rgb(255 255 255 / 0.78);
  border-radius: calc(var(--radius-lg) + 0.25rem);
  background:
    radial-gradient(circle at top right, rgb(185 137 68 / 0.16), transparent 24%),
    radial-gradient(circle at bottom left, rgb(116 43 57 / 0.09), transparent 20%),
    linear-gradient(180deg, rgb(255 255 255 / 0.88), rgb(255 255 255 / 0.74));
  box-shadow: var(--shadow-card);
  backdrop-filter: blur(16px) saturate(130%);
}

.hero__inner::before {
  position: absolute;
  inset: auto auto -2.5rem -2.5rem;
  width: 12rem;
  height: 12rem;
  border-radius: 50%;
  background: radial-gradient(circle, rgb(116 43 57 / 0.1), transparent 70%);
  content: '';
}

.hero__inner > * {
  position: relative;
  z-index: 1;
}

.hero__text {
  min-width: 0;
}

.hero__eyebrow,
.section__eyebrow {
  margin-bottom: var(--space-sm);
  color: var(--color-text-muted);
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.hero__name {
  max-width: 8ch;
  margin-bottom: 0.8rem;
}

.hero__tagline {
  max-width: 34rem;
  margin-bottom: 1.6rem;
  color: var(--color-text-secondary);
  font-size: clamp(1.08rem, 1.8vw, 1.28rem);
  line-height: 1.74;
}

.hero__actions,
.section__footer,
.netiq-spotlight__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.hero__photo-wrap {
  justify-self: center;
  width: min(100%, 430px);
}

.hero__photo-card {
  position: relative;
  overflow: hidden;
  padding: 0.95rem;
  border: 1px solid rgb(255 255 255 / 0.86);
  border-radius: calc(var(--radius-lg) - 0.1rem);
  background:
    radial-gradient(circle at top left, rgb(185 137 68 / 0.2), transparent 24%),
    radial-gradient(circle at bottom right, rgb(116 43 57 / 0.08), transparent 18%),
    linear-gradient(180deg, rgb(255 255 255 / 0.76), rgb(255 255 255 / 0.54));
  box-shadow: var(--shadow-soft);
  backdrop-filter: blur(16px) saturate(120%);
}

.hero__photo-card::before {
  position: absolute;
  inset: auto auto 0.8rem 0.8rem;
  width: 7rem;
  height: 7rem;
  border-radius: 50%;
  background: radial-gradient(circle, rgb(185 137 68 / 0.16), transparent 70%);
  content: '';
}

.hero__photo-card::after {
  position: absolute;
  inset: auto 1rem 1rem auto;
  width: 3.6rem;
  height: 3.6rem;
  border-radius: 50%;
  background: rgb(116 43 57 / 0.12);
  content: '';
}

.hero__photo {
  position: relative;
  z-index: 1;
  width: 100%;
  border-radius: calc(var(--radius-md) - 0.2rem);
  object-fit: cover;
  aspect-ratio: 4 / 5;
  box-shadow: 0 18px 36px rgb(15 23 42 / 0.12);
}

.hero__photo-fallback {
  position: relative;
  z-index: 1;
  display: grid;
  width: 100%;
  place-items: center;
  border-radius: calc(var(--radius-md) - 0.2rem);
  background:
    radial-gradient(circle at top left, rgb(185 137 68 / 0.22), transparent 24%),
    linear-gradient(180deg, rgb(255 255 255 / 0.92), rgb(255 255 255 / 0.76));
  aspect-ratio: 4 / 5;
  color: var(--color-primary);
  font-size: clamp(3rem, 7vw, 5rem);
  font-weight: 700;
  letter-spacing: -0.08em;
  box-shadow: 0 18px 36px rgb(15 23 42 / 0.12);
}

.metrics {
  padding-block: 0 var(--space-2xl);
}

.metrics__grid {
  display: grid;
  gap: 1rem;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
}

.metric-card {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
  justify-content: space-between;
  min-height: 9rem;
  padding: 1.25rem 1.3rem;
}

.metric-card__value {
  color: var(--color-primary);
  font-size: clamp(1.85rem, 4vw, 2.6rem);
  font-weight: 700;
  line-height: 1;
}

.metric-card__label {
  max-width: 16ch;
  color: var(--color-text-secondary);
  font-size: 0.92rem;
  line-height: 1.5;
}

.section {
  padding-block: 1.4rem var(--space-2xl);
}

.section__header {
  max-width: 58ch;
  margin-bottom: 1.4rem;
}

.section__title {
  margin-bottom: 0.55rem;
}

.section__lead {
  max-width: 54ch;
  color: var(--color-text-secondary);
  font-size: 1.02rem;
  line-height: 1.72;
  margin: 0;
}

.cards {
  display: grid;
  gap: 1.1rem;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
}

.card {
  display: flex;
  flex-direction: column;
  height: 100%;
  gap: 0.1rem;
}

.card__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2.6rem;
  height: 2.6rem;
  margin-bottom: 0.95rem;
  border: 1px solid rgb(116 43 57 / 0.08);
  border-radius: 50%;
  background: rgb(116 43 57 / 0.06);
  color: var(--color-primary);
  font-size: 1.15rem;
}

.card--ai .card__icon {
  color: var(--color-accent-dark);
}

.card--sec .card__icon {
  color: var(--color-primary-dark);
}

.card--dt .card__icon {
  color: var(--color-accent);
}

.card__title {
  margin-bottom: 0.7rem;
  font-size: var(--title-card);
}

.card__body {
  flex: 1;
  margin-bottom: 1.1rem;
  color: var(--color-text-secondary);
  font-size: var(--text-body);
  line-height: 1.72;
}

.card__link {
  color: var(--color-primary);
  font-size: 0.9rem;
}

.card__link::after {
  margin-left: 0.45rem;
  content: '→';
}

.netiq-spotlight__panel {
  position: relative;
  overflow: hidden;
  display: grid;
  gap: var(--space-2xl);
  align-items: center;
  padding: clamp(1.5rem, 4vw, 3rem);
  border: 1px solid rgb(255 255 255 / 0.14);
  border-radius: calc(var(--radius-lg) + 0.1rem);
  background:
    radial-gradient(circle at top right, rgb(185 137 68 / 0.24), transparent 28%),
    linear-gradient(135deg, rgb(74 22 33 / 0.96), rgb(116 43 57 / 0.9) 55%, rgb(185 137 68 / 0.74) 120%);
  color: #fff;
  box-shadow: var(--shadow-card);
}

.netiq-spotlight__panel::after {
  position: absolute;
  inset: auto -2rem -2rem auto;
  width: 10rem;
  height: 10rem;
  border-radius: 50%;
  background: radial-gradient(circle, rgb(255 255 255 / 0.16), transparent 70%);
  content: '';
}

.section__eyebrow--light {
  color: rgb(255 255 255 / 0.66);
}

.netiq-spotlight__title,
.netiq-spotlight__title .type-accent {
  color: #fff;
}

.type-accent--light {
  color: var(--color-accent-light);
}

.netiq-spotlight__body {
  max-width: 54ch;
  margin-bottom: var(--space-lg);
  color: rgb(255 255 255 / 0.82);
  font-size: 1rem;
  line-height: 1.8;
}

.netiq-spotlight__services {
  display: grid;
  gap: 0.75rem;
  margin: 0 0 var(--space-xl);
  padding: 0;
  list-style: none;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.netiq-spotlight__services li {
  padding: 0.9rem 1rem;
  border: 1px solid rgb(255 255 255 / 0.14);
  border-radius: var(--radius-md);
  background: rgb(255 255 255 / 0.09);
  color: rgb(255 255 255 / 0.92);
  line-height: 1.55;
  backdrop-filter: blur(14px);
}

.netiq-spotlight__services li::before {
  margin-right: 0.55rem;
  color: var(--color-accent-light);
  content: '•';
}

.netiq-spotlight__visual {
  justify-self: center;
  width: min(100%, 340px);
  padding: 1.2rem;
  border: 1px solid rgb(255 255 255 / 0.12);
  border-radius: 30px;
  background: rgb(255 255 255 / 0.06);
  opacity: 0.96;
  backdrop-filter: blur(14px);
}

.network-svg {
  width: 100%;
  height: auto;
}

.highlights {
  display: grid;
  gap: 1.1rem;
}

.highlight {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
  padding: 1.25rem;
}

.highlight__date {
  min-width: auto;
  padding: 0.42rem 0.7rem;
  border: 1px solid rgb(20 24 33 / 0.08);
  border-radius: var(--radius-pill);
  background: rgb(248 250 252 / 0.96);
  color: var(--color-primary);
  font-family: var(--font-mono);
  font-size: 0.78rem;
  font-style: normal;
  font-weight: 700;
  line-height: 1.1;
}

.highlight__text {
  margin: 0;
  color: var(--color-text-secondary);
  font-size: var(--text-body);
  line-height: 1.7;
}

.section__footer {
  margin-top: 1.15rem;
}

.highlight__text strong {
  color: var(--color-text-primary);
}

@media (max-width: 767px) {
  .hero__inner {
    grid-template-columns: 1fr;
  }

  .hero__text {
    text-align: center;
  }

  .hero__name {
    max-width: none;
  }

  .hero__tagline {
    margin-inline: auto;
  }

  .hero__actions,
  .section__footer,
  .netiq-spotlight__actions {
    justify-content: center;
  }

  .metric-card {
    min-height: auto;
  }

  .highlight {
    flex-direction: column;
  }
}

@media (min-width: 900px) {
  .hero__inner,
  .netiq-spotlight__panel {
    grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
  }

  .highlights {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { netiqSchema } from '../data/schema-organization';

const title = 'NetIQ';
const description =
  'NetIQ is a Vietnamese consulting and training firm specialising in Organisational Network Analysis, AI champion programs, and AI strategy advisory services for organisations across Vietnam and Southeast Asia.';
const canonicalUrl = '/netiq';

const services = [
  {
    icon: '⬡',
    name: 'ONA Consulting & Diagnostics',
    summary: "Map your organisation's real relationship networks",
    body: 'We design and administer multiplex ONA surveys across five network layers — Work Advice, AI Support, Trust, Information, and Collaboration — then use network-science algorithms to identify key brokers, silos, and high-centrality nodes. Deliverables include interactive network visualisations, a diagnostic report, and a leadership briefing with prioritised recommendations.',
  },
  {
    icon: '◈',
    name: 'AI Champion Program Design',
    summary: 'Identify and empower your internal AI advocates',
    body: 'Using betweenness centrality and Infomap community detection on your ONA data, we identify Oracle, Broker, and Silo-Buster archetypes and design a tailored AI champion program — including selection criteria, onboarding, activation playbooks, and progress-measurement frameworks.',
  },
  {
    icon: '◲',
    name: 'AI Strategy Training for Executives',
    summary: 'Build leadership fluency in AI across three stages',
    body: 'Our executive education programme covers AI readiness assessment, strategic planning for AI adoption, and implementation governance — contextualised for Vietnamese and Southeast Asian regulatory, cultural, and competitive environments. Available as in-person workshops or blended formats.',
  },
  {
    icon: '◉',
    name: 'Research & Advisory Services',
    summary: 'Independent research support and strategic advisory',
    body: 'We support organisations, government agencies, and academic institutions with independent research design, data collection, network analysis, and interpretation. Services include custom ONA study design, literature synthesis, policy advisory, and co-authorship on applied research projects.',
  },
];

const methodology = [
  { step: '01', label: 'Needs Assessment', desc: 'Stakeholder interviews and organisational context mapping to define the right ONA scope and questions.' },
  { step: '02', label: 'Survey Design & Administration', desc: 'Validated multiplex ONA survey instruments administered across target populations, with anonymisation protocols.' },
  { step: '03', label: 'Network Analysis', desc: 'Betweenness centrality, degree centrality, Infomap community detection, and multiplex correlation analysis applied to clean relational data.' },
  { step: '04', label: 'Interpretation & Reporting', desc: 'Interactive visualisations, executive summary, diagnostic report, and leadership workshop to interpret findings and plan actions.' },
  { step: '05', label: 'Program Design & Implementation', desc: 'Design of AI champion programs, intervention plans, or structural changes informed by ONA findings.' },
  { step: '06', label: 'Follow-up & Measurement', desc: 'Repeat ONA assessment (6–12 months) to measure network change and evaluate program impact.' },
];
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  canonicalUrl={canonicalUrl}
  jsonLd={netiqSchema}
>
  <!-- ── NetIQ Hero ── -->
  <section class="netiq-hero">
    <div class="container netiq-hero__inner">
      <div class="netiq-hero__text">
        <p class="netiq-hero__eyebrow">Consulting · Training · Research</p>
        <h1 class="netiq-hero__title">NetIQ</h1>
        <p class="netiq-hero__sub">
          Vietnam's specialist in Organisational Network Analysis and AI strategy
        </p>
        <p class="netiq-hero__body">
          NetIQ was co-founded by Dr. Duy Dang-Pham to translate cutting-edge network-science
          research into practical solutions for Vietnamese and Southeast Asian organisations.
          We help leadership teams understand the real — not the org-chart — structure of
          their organisations, and use those insights to design more effective AI adoption
          strategies.
        </p>
        <div class="netiq-hero__actions">
          <a class="btn btn--white" href="/contact">Work with NetIQ</a>
          <a class="btn btn--ghost" href="#services">Our services ↓</a>
        </div>
      </div>
      <div class="netiq-hero__visual" aria-hidden="true">
        <svg viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="150" cy="150" r="30" fill="#fff" opacity="0.9"/>
          <circle cx="70"  cy="80"  r="18" fill="#fff" opacity="0.6"/>
          <circle cx="230" cy="80"  r="18" fill="#fff" opacity="0.6"/>
          <circle cx="60"  cy="220" r="15" fill="#fff" opacity="0.5"/>
          <circle cx="240" cy="220" r="15" fill="#fff" opacity="0.5"/>
          <circle cx="150" cy="38"  r="12" fill="#fff" opacity="0.5"/>
          <circle cx="42"  cy="150" r="12" fill="#fff" opacity="0.45"/>
          <circle cx="258" cy="150" r="12" fill="#fff" opacity="0.45"/>
          <circle cx="150" cy="262" r="12" fill="#fff" opacity="0.5"/>
          <circle cx="105" cy="105" r="9"  fill="#fff" opacity="0.4"/>
          <circle cx="195" cy="105" r="9"  fill="#fff" opacity="0.4"/>
          <circle cx="105" cy="195" r="9"  fill="#fff" opacity="0.4"/>
          <circle cx="195" cy="195" r="9"  fill="#fff" opacity="0.4"/>
          <line x1="150" y1="150" x2="70"  y2="80"  stroke="#fff" stroke-width="1.5" opacity="0.35"/>
          <line x1="150" y1="150" x2="230" y2="80"  stroke="#fff" stroke-width="1.5" opacity="0.35"/>
          <line x1="150" y1="150" x2="60"  y2="220" stroke="#fff" stroke-width="1.5" opacity="0.35"/>
          <line x1="150" y1="150" x2="240" y2="220" stroke="#fff" stroke-width="1.5" opacity="0.35"/>
          <line x1="70"  y1="80"  x2="150" y2="38"  stroke="#fff" stroke-width="1"   opacity="0.25"/>
          <line x1="230" y1="80"  x2="150" y2="38"  stroke="#fff" stroke-width="1"   opacity="0.25"/>
          <line x1="60"  y1="220" x2="150" y2="262" stroke="#fff" stroke-width="1"   opacity="0.25"/>
          <line x1="240" y1="220" x2="150" y2="262" stroke="#fff" stroke-width="1"   opacity="0.25"/>
          <line x1="70"  y1="80"  x2="42"  y2="150" stroke="#fff" stroke-width="1"   opacity="0.2"/>
          <line x1="230" y1="80"  x2="258" y2="150" stroke="#fff" stroke-width="1"   opacity="0.2"/>
          <line x1="105" y1="105" x2="70"  y2="80"  stroke="#fff" stroke-width="1"   opacity="0.2"/>
          <line x1="195" y1="105" x2="230" y2="80"  stroke="#fff" stroke-width="1"   opacity="0.2"/>
        </svg>
      </div>
    </div>
  </section>

  <div class="container--content">

    <!-- ── Services ── -->
    <section class="section-block" id="services">
      <h2>Services</h2>
      <div class="services-grid">
        {services.map((s) => (
          <article class="service-card">
            <div class="service-card__icon" aria-hidden="true">{s.icon}</div>
            <h3 class="service-card__name">{s.name}</h3>
            <p class="service-card__summary">{s.summary}</p>
            <p class="service-card__body">{s.body}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ── Methodology ── -->
    <section class="section-block" id="methodology">
      <h2>Our methodology</h2>
      <p class="section-lead">
        NetIQ's ONA engagements follow a structured six-step process grounded in the
        academic research of Dr. Dang-Pham and validated across Vietnamese and
        international organisations.
      </p>
      <ol class="methodology-steps">
        {methodology.map((m) => (
          <li class="method-step">
            <span class="method-step__number">{m.step}</span>
            <div>
              <strong class="method-step__label">{m.label}</strong>
              <p class="method-step__desc">{m.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- ── Why NetIQ ── -->
    <section class="section-block why-netiq">
      <h2>Why NetIQ</h2>
      <div class="why-grid">
        <div class="why-item">
          <strong>Academic rigour</strong>
          <p>Methods developed and validated through 60+ peer-reviewed publications — not vendor frameworks or guesswork.</p>
        </div>
        <div class="why-item">
          <strong>Local context expertise</strong>
          <p>15+ years researching Vietnamese and Southeast Asian organisations — we understand your cultural, regulatory, and competitive environment.</p>
        </div>
        <div class="why-item">
          <strong>End-to-end delivery</strong>
          <p>From survey design and data collection to analysis, visualisation, leadership workshops, and program implementation support.</p>
        </div>
        <div class="why-item">
          <strong>Actionable outputs</strong>
          <p>Every engagement culminates in practical recommendations your leadership team can act on — not academic reports that gather dust.</p>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="netiq-cta">
      <h2>Ready to map your organisation?</h2>
      <p>
        Whether you are beginning an AI transformation, facing unexplained knowledge-sharing
        problems, or designing a change management initiative, an ONA diagnostic can illuminate
        exactly what is happening beneath the surface. Let's talk.
      </p>
      <a class="cta-btn" href="/contact">Contact NetIQ →</a>
    </section>

  </div>
</BaseLayout>

<style>
.netiq-hero {
  padding-block: 0.75rem var(--space-2xl);
}

.netiq-hero__inner {
  position: relative;
  overflow: hidden;
  display: grid;
  align-items: center;
  gap: var(--space-2xl);
  padding: clamp(1.6rem, 4vw, 3rem);
  border: 1px solid rgb(255 255 255 / 0.16);
  border-radius: calc(var(--radius-lg) + 0.2rem);
  background:
    radial-gradient(circle at top right, rgb(185 137 68 / 0.24), transparent 24%),
    linear-gradient(135deg, rgb(74 22 33 / 0.96), rgb(116 43 57 / 0.9) 56%, rgb(185 137 68 / 0.76) 120%);
  color: #fff;
  box-shadow: var(--shadow-card);
}

.netiq-hero__inner::after {
  position: absolute;
  inset: auto -3rem -3rem auto;
  width: 12rem;
  height: 12rem;
  border-radius: 50%;
  background: radial-gradient(circle, rgb(255 255 255 / 0.14), transparent 68%);
  content: '';
}

.netiq-hero__inner > * {
  position: relative;
  z-index: 1;
}

.netiq-hero__text {
  min-width: 0;
}

.netiq-hero__eyebrow {
  margin-bottom: var(--space-sm);
  color: rgb(255 255 255 / 0.66);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.netiq-hero__title {
  margin-bottom: 0.45rem;
  color: #fff;
  font-size: clamp(2.75rem, 7vw, 4.6rem);
}

.netiq-hero__sub {
  margin-bottom: var(--space-lg);
  color: rgb(255 255 255 / 0.84);
  font-size: 1.05rem;
  font-weight: 600;
  letter-spacing: -0.01em;
}

.netiq-hero__body {
  max-width: 54ch;
  margin-bottom: 1.5rem;
  color: rgb(255 255 255 / 0.82);
  font-size: 1rem;
  line-height: 1.76;
}

.netiq-hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
}

.netiq-hero__visual {
  width: min(100%, 320px);
  padding: 1.2rem;
  border: 1px solid rgb(255 255 255 / 0.14);
  border-radius: 30px;
  background: rgb(255 255 255 / 0.08);
  box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.06);
  backdrop-filter: blur(14px);
}

.netiq-hero__visual svg {
  width: 100%;
  height: auto;
}

.section-block {
  padding-top: 0;
}

.section-block h2 {
  font-size: 1.35rem;
}

.section-lead {
  margin-bottom: var(--space-lg);
  color: var(--color-text-secondary);
  line-height: 1.72;
}

.services-grid {
  display: grid;
  gap: var(--space-lg);
}

.service-card {
  padding: 1.35rem;
}

.service-card__icon {
  margin-bottom: 0.9rem;
  color: var(--color-primary);
  font-size: 1.35rem;
}

.service-card__name {
  margin-bottom: 0.3rem;
  font-size: 1.08rem;
}

.service-card__summary {
  margin-bottom: 0.75rem;
  color: var(--color-primary);
  font-size: 0.88rem;
  font-style: italic;
  font-weight: 600;
}

.service-card__body {
  margin: 0;
  color: var(--color-text-secondary);
  font-size: 0.94rem;
  line-height: 1.7;
}

.methodology-steps {
  display: grid;
  gap: var(--space-md);
  margin: 0;
  padding: 0;
  list-style: none;
}

.method-step {
  display: flex;
  gap: var(--space-lg);
  align-items: flex-start;
  padding: 1.15rem 1.25rem;
}

.method-step__number {
  flex-shrink: 0;
  width: 2.3rem;
  height: 2.3rem;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary), #924355);
  color: #fff;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 700;
  box-shadow: 0 14px 28px rgb(116 43 57 / 0.18);
}

.method-step__label {
  display: block;
  margin-bottom: 0.25rem;
  font-size: 0.98rem;
}

.method-step__desc {
  margin: 0;
  color: var(--color-text-secondary);
  font-size: 0.9rem;
  line-height: 1.65;
}

.why-grid {
  display: grid;
  gap: var(--space-md);
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
}

.why-item {
  padding: 1.2rem;
  border-top: 3px solid var(--color-primary);
}

.why-item strong {
  display: block;
  margin-bottom: var(--space-sm);
}

.why-item p {
  margin: 0;
  color: var(--color-text-secondary);
  font-size: 0.92rem;
  line-height: 1.65;
}

.netiq-cta {
  margin-bottom: var(--space-2xl);
  text-align: left;
}

.netiq-cta h2 {
  font-size: 1.4rem;
  margin-bottom: var(--space-md);
}

.netiq-cta p {
  max-width: 58ch;
  margin-bottom: var(--space-lg);
  color: var(--color-text-secondary);
  line-height: 1.72;
}

@media (max-width: 767px) {
  .netiq-hero__visual {
    width: min(100%, 220px);
    margin-inline: auto;
  }
}

@media (min-width: 768px) {
  .services-grid {
    grid-template-columns: 1fr 1fr;
  }
}

@media (min-width: 960px) {
  .netiq-hero__inner {
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
  }
}
</style>

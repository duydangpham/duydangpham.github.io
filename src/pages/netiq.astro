---
import BaseLayout from '../layouts/BaseLayout.astro';
import { netiqSchema } from '../data/schema-organization';

const title = 'NetIQ';
const description =
  "NetIQ is Vietnam's specialist in Organisational Network Analysis, helping organisations navigate change initiatives across AI adoption, digital transformation, leadership, and beyond. Founded by Dr. Duy Dang-Pham and grounded in peer-reviewed research.";
const canonicalUrl = '/netiq';

const services = [
  {
    icon: '⬡',
    name: 'ONA Consulting & Diagnostics',
    summary: "Map your organisation's real relationship networks",
  },
  {
    icon: '◈',
    name: 'AI Champion Program Design',
    summary: 'Identify and empower your internal AI advocates',
  },
  {
    icon: '◲',
    name: 'AI Strategy Training for Executives',
    summary: 'Build leadership fluency in AI across three stages',
  },
  {
    icon: '◉',
    name: 'Research & Advisory Services',
    summary: 'Independent research support and strategic advisory',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  canonicalUrl={canonicalUrl}
  jsonLd={netiqSchema}
>
  <!-- ── NetIQ Hero ── -->
  <section class="netiq-hero">
    <div class="container netiq-hero__inner">
      <div class="netiq-hero__text">
        <p class="netiq-hero__eyebrow">Consulting · Training · Advisory</p>
        <h1 class="netiq-hero__title">NetIQ</h1>
        <p class="netiq-hero__sub">
          Vietnam's specialist in Organisational Network Analysis for change-driven organisations
        </p>
        <p class="netiq-hero__body">
          Behind every change initiative — whether it is an AI rollout, a leadership
          restructure, a DEI programme, or a post-merger integration — there is a
          human network that will determine whether it succeeds or fails.
          Organisational Network Analysis makes that network visible. NetIQ was founded
          by Dr. Duy Dang-Pham to bring the rigour of academic network science to
          Vietnamese and Southeast Asian organisations navigating exactly that
          challenge. Our deepest expertise lies in AI adoption, digital transformation,
          and information security — but ONA works wherever relationships, trust, and
          informal influence shape whether change takes hold.
        </p>
        <div class="netiq-hero__actions">
          <a
            class="btn btn--white"
            href="https://netiq.vn"
            target="_blank"
            rel="noopener noreferrer"
          >
            Visit netiq.vn
          </a>
          <a class="btn btn--ghost" href="#services">Our services ↓</a>
        </div>
      </div>
      <div class="netiq-hero__visual" aria-hidden="true">
        <svg viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="150" cy="150" r="30" fill="#fff" opacity="0.9"/>
          <circle cx="70"  cy="80"  r="18" fill="#fff" opacity="0.6"/>
          <circle cx="230" cy="80"  r="18" fill="#fff" opacity="0.6"/>
          <circle cx="60"  cy="220" r="15" fill="#fff" opacity="0.5"/>
          <circle cx="240" cy="220" r="15" fill="#fff" opacity="0.5"/>
          <circle cx="150" cy="38"  r="12" fill="#fff" opacity="0.5"/>
          <circle cx="42"  cy="150" r="12" fill="#fff" opacity="0.45"/>
          <circle cx="258" cy="150" r="12" fill="#fff" opacity="0.45"/>
          <circle cx="150" cy="262" r="12" fill="#fff" opacity="0.5"/>
          <circle cx="105" cy="105" r="9"  fill="#fff" opacity="0.4"/>
          <circle cx="195" cy="105" r="9"  fill="#fff" opacity="0.4"/>
          <circle cx="105" cy="195" r="9"  fill="#fff" opacity="0.4"/>
          <circle cx="195" cy="195" r="9"  fill="#fff" opacity="0.4"/>
          <line x1="150" y1="150" x2="70"  y2="80"  stroke="#fff" stroke-width="1.5" opacity="0.35"/>
          <line x1="150" y1="150" x2="230" y2="80"  stroke="#fff" stroke-width="1.5" opacity="0.35"/>
          <line x1="150" y1="150" x2="60"  y2="220" stroke="#fff" stroke-width="1.5" opacity="0.35"/>
          <line x1="150" y1="150" x2="240" y2="220" stroke="#fff" stroke-width="1.5" opacity="0.35"/>
          <line x1="70"  y1="80"  x2="150" y2="38"  stroke="#fff" stroke-width="1"   opacity="0.25"/>
          <line x1="230" y1="80"  x2="150" y2="38"  stroke="#fff" stroke-width="1"   opacity="0.25"/>
          <line x1="60"  y1="220" x2="150" y2="262" stroke="#fff" stroke-width="1"   opacity="0.25"/>
          <line x1="240" y1="220" x2="150" y2="262" stroke="#fff" stroke-width="1"   opacity="0.25"/>
          <line x1="70"  y1="80"  x2="42"  y2="150" stroke="#fff" stroke-width="1"   opacity="0.2"/>
          <line x1="230" y1="80"  x2="258" y2="150" stroke="#fff" stroke-width="1"   opacity="0.2"/>
          <line x1="105" y1="105" x2="70"  y2="80"  stroke="#fff" stroke-width="1"   opacity="0.2"/>
          <line x1="195" y1="105" x2="230" y2="80"  stroke="#fff" stroke-width="1"   opacity="0.2"/>
        </svg>
      </div>
    </div>
  </section>

  <div class="container--content netiq-shell">

    <!-- ── Services ── -->
    <section class="section-block" id="services">
      <h2>Services</h2>
      <p class="section-lead">
        ONA has been applied to leadership effectiveness, communication flow, DEI
        initiatives, knowledge management, and change management broadly. The services
        below represent our core practice areas — anchored in Dr. Dang-Pham's research
        expertise.
      </p>
      <div class="services-grid">
        {services.map((s) => (
          <article class="service-card">
            <div class="service-card__icon" aria-hidden="true">{s.icon}</div>
            <h3 class="service-card__name">{s.name}</h3>
            <p class="service-card__summary">{s.summary}</p>
          </article>
        ))}
      </div>
      <p class="section-lead services-note">
        Full service details, engagement formats, and case studies are available at
        netiq.vn
      </p>
      <a
        class="btn btn--outline"
        href="https://netiq.vn"
        target="_blank"
        rel="noopener noreferrer"
      >
        Explore services at netiq.vn
      </a>
    </section>

    <!-- ── Why NetIQ ── -->
    <section class="section-block why-netiq">
      <h2>Why NetIQ</h2>
      <div class="why-grid">
        <div class="why-item">
          <strong>Academic rigour</strong>
          <p>
            Our methods have been tested, challenged, and refined across 70+
            peer-reviewed publications — not assembled from a proprietary playbook.
            When we tell you something about your organisation's network, the science
            supports it.
          </p>
        </div>
        <div class="why-item">
          <strong>Broad application, deep expertise</strong>
          <p>
            ONA can be applied wherever human networks shape organisational outcomes —
            leadership, communication, DEI, knowledge management, and change
            management of any kind. Our deepest research expertise lies in AI adoption,
            digital transformation, and information security, but the diagnostic
            methodology is universal.
          </p>
        </div>
        <div class="why-item">
          <strong>One team, start to finish</strong>
          <p>
            You don't manage multiple vendors or translate findings into action
            yourself. We take you from scoping question to implemented programme in a
            single continuous engagement — with one team accountable throughout.
          </p>
        </div>
        <div class="why-item">
          <strong>Actionable outputs</strong>
          <p>
            Every engagement closes with specific, prioritised actions your leadership
            team can begin implementing within weeks — not a report that answers one
            question and raises three more.
          </p>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="netiq-cta">
      <h2>Ready to work with NetIQ?</h2>
      <p>
        If your organisation is navigating a change initiative — whether that is AI
        adoption, a structural reorganisation, a cultural transformation, or something
        else entirely — ONA can show you what is actually happening in the networks
        that will determine your outcome. For service details, engagement formats, and
        enquiries, head to the NetIQ website. If you'd like to reach Dr. Dang-Pham
        directly about research collaboration or speaking, use the contact page on
        this site.
      </p>
      <a
        class="cta-btn"
        href="https://netiq.vn"
        target="_blank"
        rel="noopener noreferrer"
      >
        Go to netiq.vn →
      </a>
    </section>

  </div>
</BaseLayout>

<style>
.netiq-hero {
  padding-block: 0.75rem var(--space-2xl);
}

.netiq-hero__inner {
  position: relative;
  overflow: hidden;
  display: grid;
  align-items: center;
  gap: var(--space-2xl);
  padding: clamp(1.6rem, 4vw, 3rem);
  border: 1px solid rgb(255 255 255 / 0.16);
  border-radius: calc(var(--radius-lg) + 0.2rem);
  background:
    radial-gradient(circle at top right, rgb(185 137 68 / 0.24), transparent 24%),
    linear-gradient(135deg, rgb(74 22 33 / 0.96), rgb(116 43 57 / 0.9) 56%, rgb(185 137 68 / 0.76) 120%);
  color: #fff;
  box-shadow: var(--shadow-card);
}

.netiq-hero__inner::after {
  position: absolute;
  inset: auto -3rem -3rem auto;
  width: 12rem;
  height: 12rem;
  border-radius: 50%;
  background: radial-gradient(circle, rgb(255 255 255 / 0.14), transparent 68%);
  content: '';
}

.netiq-hero__inner > * {
  position: relative;
  z-index: 1;
}

.netiq-hero__text {
  min-width: 0;
}

.netiq-hero__eyebrow {
  margin-bottom: var(--space-sm);
  color: rgb(255 255 255 / 0.66);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.netiq-hero__title {
  margin-bottom: 0.45rem;
  color: #fff;
  font-size: clamp(2.75rem, 7vw, 4.6rem);
}

.netiq-hero__sub {
  margin-bottom: var(--space-lg);
  color: rgb(255 255 255 / 0.84);
  font-size: 1.05rem;
  font-weight: 600;
  letter-spacing: -0.01em;
}

.netiq-hero__body {
  max-width: 57ch;
  margin-bottom: 1.5rem;
  color: rgb(255 255 255 / 0.82);
  font-size: 1rem;
  line-height: 1.76;
}

.netiq-hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
}

.netiq-hero__visual {
  justify-self: end;
  width: min(100%, 300px);
  padding: 1.2rem;
  border: 1px solid rgb(255 255 255 / 0.14);
  border-radius: 30px;
  background: rgb(255 255 255 / 0.08);
  box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.06);
  backdrop-filter: blur(14px);
}

.netiq-hero__visual svg {
  width: 100%;
  height: auto;
}

.section-block {
  padding-top: 0;
  display: grid;
  gap: var(--space-md);
}

.netiq-shell :is(.section-block, .netiq-cta) {
  padding: clamp(1.5rem, 3vw, 2.35rem);
}

.section-block h2 {
  margin-bottom: 0;
  font-size: 1.35rem;
}

.section-block + .section-block,
.section-block + .netiq-cta {
  margin-top: clamp(1.75rem, 3vw, 2.5rem);
}

.section-lead {
  max-width: 58ch;
  margin-bottom: 0;
  color: var(--color-text-secondary);
  line-height: 1.72;
}

.services-grid {
  display: grid;
  gap: var(--space-lg);
  margin-top: var(--space-xs);
}

.service-card {
  padding: 1.35rem;
}

.service-card__icon {
  margin-bottom: 0.9rem;
  color: var(--color-primary);
  font-size: 1.35rem;
}

.service-card__name {
  margin-bottom: 0.3rem;
  font-size: 1.08rem;
}

.service-card__summary {
  margin: 0;
  color: var(--color-primary);
  font-size: 0.88rem;
  font-style: italic;
  font-weight: 600;
}

.services-note {
  margin-top: var(--space-lg);
  margin-bottom: var(--space-md);
}

.why-grid {
  display: grid;
  gap: var(--space-md);
  align-items: start;
  grid-template-columns: 1fr;
}

.why-item {
  padding: clamp(1.1rem, 2vw, 1.35rem);
  border-top: 3px solid var(--color-primary);
}

.why-item strong {
  display: block;
  margin-bottom: var(--space-sm);
}

.why-item p {
  margin: 0;
  color: var(--color-text-secondary);
  font-size: 0.92rem;
  line-height: 1.65;
}

.netiq-cta {
  margin-bottom: var(--space-2xl);
  text-align: left;
}

.netiq-cta h2 {
  font-size: 1.4rem;
  margin-bottom: var(--space-md);
}

.netiq-cta p {
  max-width: 56ch;
  margin-bottom: var(--space-lg);
  color: var(--color-text-secondary);
  line-height: 1.72;
}

@media (min-width: 900px) {
  .netiq-shell :is(.section-block, .netiq-cta) {
    padding-inline: clamp(2.2rem, 4.4vw, 3.4rem);
  }
}

@media (max-width: 767px) {
  .netiq-hero__visual {
    width: min(100%, 220px);
    margin-inline: auto;
  }
}

@media (min-width: 768px) {
  .services-grid {
    grid-template-columns: 1fr 1fr;
  }

  .why-grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }
}

@media (min-width: 960px) {
  .netiq-hero__inner {
    grid-template-columns: minmax(0, 1.32fr) minmax(240px, 0.68fr);
    gap: clamp(1.6rem, 3vw, 2.35rem);
  }
}
</style>
